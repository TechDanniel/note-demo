{
  "name": "note-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:app": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs --port 5174",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "dev:all": "concurrently -k -n app,docs \"pnpm run dev:app\" \"pnpm run docs:dev\""
  },
  "dependencies": {
    "@xenova/transformers": "^2.21.0",
    "openai": "^6.32.0",
    "vue": "^3.5.25"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^9.2.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitepress": "2.0.0-alpha.16",
    "vue-tsc": "^3.1.5"
  }
}
